#!/usr/bin/env bash
# Route automated changes through a feature branch and PR. CI applies the path guard.
# Explicit operator override: ALLOW_MAIN_PUSH=1 git push ...
[ "${ALLOW_MAIN_PUSH:-0}" = "1" ] && exit 0
while read -r _local_ref _local_sha remote_ref _remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    echo "pre-push: direct main push blocked; use a branch and PR (override: ALLOW_MAIN_PUSH=1)" >&2
    exit 1
  fi
done
exit 0
